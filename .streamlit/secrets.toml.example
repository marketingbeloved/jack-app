# Copy this file to .streamlit/secrets.toml locally, OR paste the contents into
# Streamlit Cloud → App → Settings → Secrets. Never commit the real secrets.toml.

# Gemini (vision + cloud text fallback). Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY = "AIza...your-key..."

# Notion integration token (writes Dina's briefs into the Videos DB)
NOTION_TOKEN = "secret_...your-token..."

# Google Sheets — Vika's task queue
VIKA_SHEET_ID = "1AbC...the-spreadsheet-id-from-its-URL..."

# Service account JSON for Google Sheets (paste the whole key file here)
[gcp_service_account]
type = "service_account"
project_id = "your-project"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "jack-sheets@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
