# Скопируй этот файл в .streamlit/secrets.toml и впиши реальные значения.
# Реальные значения тебе даст Дарья (они общие для команды). secrets.toml в git НЕ коммитим.

# Пароль на вход в приложение (общий для команды)
APP_PASSWORD = "..."

# Общая база ТЗ (Supabase) — чтобы то, что ты сохраняешь, видели все, и наоборот.
SUPABASE_URL = "https://...your-project....supabase.co"
SUPABASE_KEY = "sb_secret_..."

# Мозг Джека в облаке. На маке Джек пишет через бесплатный claude CLI;
# на Streamlit Cloud claude CLI нет — там генерация идёт через Anthropic API.
# Без этого ключа на сайте Джек будет «offline» (читать можно, писать нельзя).
ANTHROPIC_API_KEY = "sk-ant-..."
# (необязательно) модель; по умолчанию claude-sonnet-4-6
# ANTHROPIC_MODEL = "claude-sonnet-4-6"

# «Зрение» Джека — смотрит на картинки Вики и пишет к ним текст.
# Нужен в облаке для опции «📸 Картинки Вики → Джек напишет текст».
GEMINI_API_KEY = "AIza..."
