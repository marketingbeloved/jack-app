# Скопируй этот файл в .streamlit/secrets.toml и впиши реальные значения.
# Реальные значения тебе даст Дарья (они общие для команды). secrets.toml в git НЕ коммитим.

# Пароль на вход в приложение (общий для команды)
APP_PASSWORD = "..."

# Общая база ТЗ (Supabase) — чтобы то, что ты сохраняешь, видели все, и наоборот.
SUPABASE_URL = "https://...your-project....supabase.co"
SUPABASE_KEY = "sb_secret_..."
